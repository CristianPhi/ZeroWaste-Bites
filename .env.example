# Prefer one of these options:
# 1) Single URI
MONGODB_URI=mongodb+srv://<username>:<url-encoded-password>@<cluster-host>/<db-name>?retryWrites=true&w=majority&appName=<app-name>

# 2) Split variables (password can be plain; app builds URI safely)
# MONGODB_USER=<username>
# MONGODB_PASS=<password>
# MONGODB_HOST=<cluster-host>
# MONGODB_DB=zerowaste_db
# MONGODB_APP_NAME=ZeroWasteBites
